<launch>

    <let
        name="urdf_path"
        value="$(find-pkg-share manip_description)/urdf/manip.urdf.xacro"/>

    <let name="rviz_config_path"
        value="$(find-pkg-share manip_bringup)/config/manip_moveit.rviz"/>

            <arg name="use_mock_components" default="false"/>
            <arg name="launch_realsense" default="true"/>
            <arg name="launch_apriltag" default="true"/>
            <arg name="launch_pick_action" default="true"/>
            <arg name="launch_place_action" default="true"/>
            <arg name="launch_speech" default="true"/>
            <arg name="piper_executable" default="auto"/>
            <arg name="piper_model" default="$(find-pkg-share manip_audio)/models/pt_BR-jeff/pt_BR-jeff-medium.onnx"/>
            <arg name="speech_player_executable" default="auto"/>
            <arg name="launch_pick_telemetry" default="false"/>
            <arg name="verify_grasp_effort" default="true"/>
            <arg name="grasp_min_effort_nm" default="0.15"/>
            <arg name="grasp_min_effort_increase_nm" default="0.05"/>
            <arg name="grasp_retry_attempts" default="2"/>
            <arg name="switch_ik_after_failed_grasp" default="true"/>
            <arg name="attempt_1_ik_solver" default="pick_ik/PickIkPlugin"/>
            <arg name="attempt_2_ik_solver" default="kdl_kinematics_plugin/KDLKinematicsPlugin"/>
            <arg name="attempt_3_ik_solver" default="pick_ik/PickIkPlugin"/>
            <arg name="attempt_3_ik_solve_type" default="Distance"/>
            <arg name="attempt_3_ik_position_only" default="false"/>
            <arg name="attempt_3_ik_position_threshold" default="0.010"/>
            <arg name="attempt_3_ik_orientation_threshold" default="0.90"/>
            <arg name="attempt_3_goal_position_tolerance" default="0.010"/>
            <arg name="attempt_3_goal_orientation_tolerance" default="0.80"/>
            <arg name="skip_failed_pick_after_retries" default="true"/>
            <arg name="skip_missing_place_tag" default="true"/>
            <arg name="use_camera_alignment_retry" default="true"/>
            <arg name="fallback_ik_solver" default="pick_ik/PickIkPlugin"/>
            <arg name="fallback_ik_mode" default="local"/>
            <arg name="fallback_ik_solve_type" default="Distance"/>
            <arg name="fallback_ik_position_only" default="true"/>
            <arg name="reset_container_states" default="true"/>
            <arg name="apriltag_params_file" default="$(env HOME)/manip_ws/src/apriltag_ros/cfg/tags_36h11.yaml"/>

    <node pkg="robot_state_publisher" exec="robot_state_publisher" >
        <param
            name="robot_description"
            value="$(command 'xacro $(var urdf_path) use_mock_components:=$(var use_mock_components)')"/>
    </node>

    <node pkg="rviz2" exec="rviz2" output="screen" 
          args="-d $(var rviz_config_path)"/>

    <node pkg="controller_manager" exec="ros2_control_node" output="screen" >
          <param
            name="robot_description"
                                    value="$(command 'xacro $(var urdf_path) use_mock_components:=$(var use_mock_components)')"/>
          <param from="$(find-pkg-share manip_bringup)/config/ros2_controllers.yaml"/>
    </node>

    <node pkg="controller_manager" exec="spawner" output="screen"
          args="arm_controller"/>  

    <node pkg="controller_manager" exec="spawner" output="screen"
          args="gripper_controller" /> 

    <node pkg="controller_manager" exec="spawner" output="screen"
          args="joint_state_broadcaster" /> 

            <include file="$(find-pkg-share manip_moveit_config)/launch/move_group.launch.py">
                  <arg name="capabilities" value="move_group/ExecuteTaskSolutionCapability"/>
            </include>

            <group if="$(var launch_realsense)">
                  <include file="$(find-pkg-share realsense2_camera)/launch/rs_launch.py">
                        <arg name="camera_name" value="camera"/>
                        <arg name="align_depth.enable" value="true"/>
                        <arg name="pointcloud.enable" value="false"/>
                        <arg name="enable_color" value="true"/>
                        <arg name="enable_depth" value="true"/>
                  </include>
            </group>

            <group if="$(var launch_apriltag)">
                  <node pkg="apriltag_ros" exec="apriltag_node" output="screen">
                        <remap from="image_rect" to="/camera/camera/color/image_raw"/>
                        <remap from="camera_info" to="/camera/camera/color/camera_info"/>
                        <param name="qos_profile" value="sensor_data"/>
                        <param from="$(var apriltag_params_file)"/>
                  </node>
            </group>

    <node pkg="manip_commander" exec="commmander"/>

            <group if="$(var launch_speech)">
                  <node pkg="manip_audio" exec="speech_node" output="screen">
                        <param name="backend" value="piper"/>
                        <param name="piper_executable" value="$(var piper_executable)"/>
                        <param name="piper_model" value="$(var piper_model)"/>
                        <param name="player_executable" value="$(var speech_player_executable)"/>
                        <param name="voice_effect" value="dog"/>
                  </node>
            </group>

            <group if="$(var launch_pick_telemetry)">
                  <node pkg="manip_task_execution" exec="pick_telemetry_plotter" output="screen"/>
            </group>

            <group if="$(var launch_pick_action)">
                  <node pkg="manip_task_execution" exec="mtc_pick_action_node" output="screen">
                        <param name="reset_container_states_on_start" value="$(var reset_container_states)"/>
                        <param name="verify_grasp_effort" value="$(var verify_grasp_effort)"/>
                        <param name="grasp_min_effort_nm" value="$(var grasp_min_effort_nm)"/>
                        <param name="grasp_min_effort_increase_nm" value="$(var grasp_min_effort_increase_nm)"/>
                        <param name="grasp_retry_attempts" value="$(var grasp_retry_attempts)"/>
                        <param name="switch_ik_after_failed_grasp" value="$(var switch_ik_after_failed_grasp)"/>
                        <param name="attempt_1_ik_solver" value="$(var attempt_1_ik_solver)"/>
                        <param name="attempt_2_ik_solver" value="$(var attempt_2_ik_solver)"/>
                        <param name="attempt_3_ik_solver" value="$(var attempt_3_ik_solver)"/>
                        <param name="attempt_3_ik_solve_type" value="$(var attempt_3_ik_solve_type)"/>
                        <param name="attempt_3_ik_position_only" value="$(var attempt_3_ik_position_only)"/>
                        <param name="attempt_3_ik_position_threshold" value="$(var attempt_3_ik_position_threshold)"/>
                        <param name="attempt_3_ik_orientation_threshold" value="$(var attempt_3_ik_orientation_threshold)"/>
                        <param name="attempt_3_goal_position_tolerance" value="$(var attempt_3_goal_position_tolerance)"/>
                        <param name="attempt_3_goal_orientation_tolerance" value="$(var attempt_3_goal_orientation_tolerance)"/>
                        <param name="fallback_ik_solver" value="$(var fallback_ik_solver)"/>
                        <param name="fallback_ik_mode" value="$(var fallback_ik_mode)"/>
                        <param name="fallback_ik_solve_type" value="$(var fallback_ik_solve_type)"/>
                        <param name="fallback_ik_position_only" value="$(var fallback_ik_position_only)"/>
                        <param name="skip_failed_pick_after_retries" value="$(var skip_failed_pick_after_retries)"/>
                        <param name="use_camera_alignment_retry" value="$(var use_camera_alignment_retry)"/>
                  </node>
            </group>

            <group if="$(var launch_place_action)">
                  <node pkg="manip_task_execution" exec="mtc_place_action_node" output="screen">
                        <param name="skip_missing_place_tag" value="$(var skip_missing_place_tag)"/>
                  </node>
            </group>

</launch>
