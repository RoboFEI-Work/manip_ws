<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="gripper_base_link">
    <visual>
        <geometry>
        <box size="0.123 0.05 0.00"/>
        </geometry>
        <origin xyz="0.0013 -0.026 -0.001"/>
        <material name="grey">
        <color rgba="0.6 0.6 0.6 1"/>
        </material>
    </visual>
        
    </link>

    <link name="finger_left">

    <visual>
        <geometry>
        <mesh filename="package://manip_description/meshes/garra.stl" scale="0.0001 0.0001 0.0001"/>
        </geometry>
        <origin xyz="0.024 0.2825 -0.301" rpy="0 3.14 -3.14"/>
        <material name="grey">
        <color rgba="0.6 0.6 0.6 1"/>
        </material>
    </visual>

    <collision>
        <geometry>
        <mesh filename="package://manip_description/meshes/garra.stl" scale="0.0001 0.0001 0.0001"/>
        </geometry>
        <origin xyz="0.024 0.283 -0.301" rpy="0 3.14 -3.14"/>
    </collision>

    <inertial>
        <mass value="0.05"/>
        <origin xyz="0.024 0.283 -0.301" rpy="0 3.14 -3.14"/>
        <inertia ixx="3e-05" ixy="0" ixz="0" iyy="3e-05" iyz="0" izz="8e-06"/>
    </inertial>

    </link>

    <joint name="manip_joint6" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="finger_left"/>
    <origin xyz="-0.0227 0 0.013"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0" upper="1.0" effort="1" velocity="5"/>
    </joint>

    <link name="finger_right">

    <visual>
        <geometry>
        <mesh filename="package://manip_description/meshes/garra.stl" scale="0.0001 0.0001 0.0001"/>
        </geometry>
        <origin xyz="-0.024 -0.283 -0.301" rpy="0 3.14 0"/>
        <material name="grey"/>
    </visual>

    <collision>
        <geometry>
        <mesh filename="package://manip_description/meshes/garra.stl" scale="0.0001 0.0001 0.0001"/>
        </geometry>
        <origin xyz="-0.024 -0.283 -0.301" rpy="0 3.14 0"/>
    </collision>

    <inertial>
        <mass value="0.05"/>
        <origin xyz="-0.024 -0.283 -0.301" rpy="0 3.14 0"/>
        <inertia ixx="3e-05" ixy="0" ixz="0" iyy="3e-05" iyz="0" izz="8e-06"/>
    </inertial>

    </link>

    <joint name="manip_joint7" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="finger_right"/>
    <origin xyz="0.027 0 0.013"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-1.0" upper="1.0" effort="1" velocity="5"/>
    </joint>

</robot>
