<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="gripper_base_link">
    <visual>
        <geometry>
        <box size="0.123 0.03 0.00"/>
        </geometry>
        <origin xyz="0 0 0.00425"/>
        <material name="grey">
        <color rgba="0.6 0.6 0.6 1"/>
        </material>
    </visual>
        
    </link>

    <link name="finger_left">

    <visual>
        <geometry>
        <mesh filename="package://manip_description/meshes/left_finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="-0.0252 0 -0.58444" rpy="0 0 0"/>
        <material name="grey">
        <color rgba="0.6 0.6 0.6 1"/>
        </material>
    </visual>

    <collision>
        <geometry>
        <mesh filename="package://manip_description/meshes/left_finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="-0.0252 0 -0.58444" rpy="0 0 0"/>
    </collision>

    <inertial>
        <mass value="0.05"/>
        <origin xyz="-0.0252 0 -0.58444" rpy="0 0 0"/>
        <inertia ixx="3e-05" ixy="0" ixz="0" iyy="3e-05" iyz="0" izz="8e-06"/>
    </inertial>

    </link>

    <joint name="manip_joint6" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="finger_left"/>
    <origin xyz="-0.0252 0 0.0215"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0" upper="1.0" effort="1" velocity="5"/>
    </joint>

    <link name="finger_right">

    <visual>
        <geometry>
        <mesh filename="package://manip_description/meshes/right_finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="0.0252 0 -0.58444" rpy="0 0 0"/>
        <material name="grey"/>
    </visual>

    <collision>
        <geometry>
        <mesh filename="package://manip_description/meshes/right_finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <origin xyz="0.0252 0 -0.58444" rpy="0 0 0"/>
    </collision>

    <inertial>
        <mass value="0.05"/>
        <origin xyz="0.0252 0 -0.58444" rpy="0 0 0"/>
        <inertia ixx="3e-05" ixy="0" ixz="0" iyy="3e-05" iyz="0" izz="8e-06"/>
    </inertial>

    </link>

    <joint name="manip_joint7" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="finger_right"/>
    <origin xyz="0.0252 0 0.0215"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-1.0" upper="1.0" effort="1" velocity="5"/>
    </joint>

</robot>
