<?xml version="1.0"?>
<robot name="manip" xmlns:xacro="http://www.ros.org/wiki/xacro">

<!-- ================= BASE ================= -->

<link name="base_link">
  <visual>
    <geometry>
      <box size="0.06 0.06 0.02"/>
    </geometry>
  </visual>
  <collision>
    <geometry>
      <box size="0.06 0.06 0.02"/>
    </geometry>
  </collision>
  <inertial>
    <mass value="0.05"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="1e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1e-05"/>
  </inertial>
</link>

<!-- ================= LINK1 ================= -->

<link name="link1">

  <visual>
    <geometry>
      <box size="0.06 0.06 0.10"/>
    </geometry>
    <origin xyz="0 0 0.05"/>
    <material name="red">
      <color rgba="1 0 0 1"/>
    </material>
  </visual>

  <collision>
    <geometry>
      <box size="0.06 0.06 0.10"/>
    </geometry>
    <origin xyz="0 0 0.05"/>
  </collision>

  <inertial>
    <mass value="0.5"/>
    <origin xyz="0 0 0.05"/>
    <inertia ixx="0.0005" ixy="0" ixz="0"
             iyy="0.0005" iyz="0"
             izz="0.0001"/>
  </inertial>

</link>

<!-- ================= LINK2 ================= -->

<link name="link2">

  <visual>
    <geometry>
      <box size="0.06 0.06 0.20"/>
    </geometry>
    <origin xyz="0 0 0.10"/>
    <material name="green">
      <color rgba="0 1 0 1"/>
    </material>
  </visual>

  <collision>
    <geometry>
      <box size="0.06 0.06 0.20"/>
    </geometry>
    <origin xyz="0 0 0.10"/>
  </collision>

  <inertial>
    <mass value="0.4"/>
    <origin xyz="0 0 0.10"/>
    <inertia ixx="0.0004" ixy="0" ixz="0"
             iyy="0.0004" iyz="0"
             izz="0.00008"/>
  </inertial>

</link>

<!-- ================= LINK3 ================= -->

<link name="link3">

  <visual>
    <geometry>
      <box size="0.06 0.06 0.20"/>
    </geometry>
    <origin xyz="0 0 0.10"/>
    <material name="blue">
      <color rgba="0 0 1 1"/>
    </material>
  </visual>

  <collision>
    <geometry>
      <box size="0.06 0.06 0.20"/>
    </geometry>
    <origin xyz="0 0 0.10"/>
  </collision>

  <inertial>
    <mass value="0.4"/>
    <origin xyz="0 0 0.10"/>
    <inertia ixx="0.0004" ixy="0" ixz="0"
             iyy="0.0004" iyz="0"
             izz="0.00008"/>
  </inertial>

</link>

<!-- ================= LINK4 ================= -->

<link name="link4">

  <visual>
    <geometry>
      <box size="0.06 0.06 0.10"/>
    </geometry>
    <origin xyz="0 0 0.05"/>
    <material name="yellow">
      <color rgba="1 1 0 1"/>
    </material>
  </visual>

  <collision>
    <geometry>
      <box size="0.06 0.06 0.10"/>
    </geometry>
    <origin xyz="0 0 0.05"/>
  </collision>

  <inertial>
    <mass value="0.3"/>
    <origin xyz="0 0 0.05"/>
    <inertia ixx="0.0003" ixy="0" ixz="0"
             iyy="0.0003" iyz="0"
             izz="0.00006"/>
  </inertial>

</link>

<!-- ================= FLANGE ================= -->

<link name="link5">

  <visual>
    <geometry>
      <box size="0.123 0.0793 0.006"/>
    </geometry>
    <origin xyz="0 0 0.003"/>
    <material name="cyan">
      <color rgba="0 1 1 1"/>
    </material>
  </visual>

  <collision>
    <geometry>
      <box size="0.123 0.0793 0.006"/>
    </geometry>
    <origin xyz="0 0 0.003"/>
  </collision>

  <inertial>
    <mass value="0.15"/>
    <origin xyz="0 0 0.003"/>
    <inertia ixx="7.9e-05" ixy="0" ixz="0"
             iyy="1.9e-04" iyz="0"
             izz="2.68e-04"/>
  </inertial>

</link>

<!-- ================= INTEL D455i ================= -->

<link name="intel_d455i_link">

  <visual>
    <geometry>
      <box size="0.1 0.025 0.029"/>
    </geometry>
    <origin xyz="0 -0.02 0.0145"/>
    <material name="camera_black">
      <color rgba="0.08 0.08 0.08 1"/>
    </material>
  </visual>

  <collision>
    <geometry>
      <box size="0.1 0.025 0.029"/>
    </geometry>
    <origin xyz="0 -0.02 0.0145"/>
  </collision>

  <inertial>
    <mass value="0.121"/>
    <origin xyz="0 -0.02 0.0145"/>
    <inertia ixx="1.0e-05" ixy="0" ixz="0"
             iyy="1.7e-04" iyz="0"
             izz="1.8e-04"/>
  </inertial>

</link>

<joint name="link5_to_intel_d455i" type="fixed">
  <parent link="link5"/>
  <child link="intel_d455i_link"/>
  <origin xyz="0 0 0.006" rpy="0 0 0"/>
</joint>

<!-- ================= ARM JOINTS ================= -->

<joint name="joint1" type="revolute">
  <parent link="base_link"/>
  <child link="link1"/>
  <axis xyz="0 0 1"/>
  <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
</joint>

<joint name="joint2" type="revolute">
  <parent link="link1"/>
  <child link="link2"/>
  <origin xyz="0 0 0.10"/>
  <axis xyz="0 1 0"/>
  <limit lower="-1.8" upper="1.8" effort="10" velocity="3"/>
</joint>

<joint name="joint3" type="revolute">
  <parent link="link2"/>
  <child link="link3"/>
  <origin xyz="0 0 0.20"/>
  <axis xyz="0 1 0"/>
  <limit lower="-2.6" upper="2.6" effort="10" velocity="1"/>
</joint>

<joint name="joint4" type="revolute">
  <parent link="link3"/>
  <child link="link4"/>
  <origin xyz="0 0 0.20"/>
  <axis xyz="0 1 0"/>
  <limit lower="-2.2" upper="2.2" effort="10" velocity="1"/>
</joint>

<joint name="joint5" type="revolute">
  <parent link="link4"/>
  <child link="link5"/>
  <origin xyz="0 0 0.10"/>
  <axis xyz="0 0 1"/>
  <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
</joint>

<!-- ================= GRIPPER JOINTS ================= -->



<!-- ================= TCP ================= -->

<link name="tcp">
  <inertial>
    <mass value="0.001"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="1e-08" ixy="0" ixz="0" iyy="1e-08" iyz="0" izz="1e-08"/>
  </inertial>
</link>

<joint name="tcp_fixed" type="fixed">
  <parent link="link5"/>
  <child link="tcp"/>
  <origin xyz="0 0 0.11025"/>
</joint>

</robot>