<?xml version="1.0"?>
<robot name="manip" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ================= REALSENSE INCLUDE ================= -->

  <xacro:include filename="$(find realsense2_description)/urdf/_d455.urdf.xacro"/>

  <!-- ================= BASE ================= -->

  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://manip_description/meshes/Base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </visual>

    <collision>
      <geometry>
        <mesh filename="package://manip_description/meshes/Base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <inertia ixx="1e-05" ixy="0" ixz="0"
               iyy="1e-05" iyz="0"
               izz="1e-05"/>
    </inertial>
  </link>

  <!-- ================= LINK1 ================= -->

  <link name="link1">

    <visual>
      <geometry>
        <mesh filename="package://manip_description/meshes/Foguete.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0.0" rpy="1.57 0 1.57"/>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <mesh filename="package://manip_description/meshes/Foguete.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0.0" rpy="1.57 0 1.57"/>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0.0"/>
      <inertia ixx="0.0005" ixy="0" ixz="0"
               iyy="0.0005" iyz="0"
               izz="0.0001"/>
    </inertial>

  </link>

  <!-- ================= LINK2 ================= -->

  <link name="link2">

    <visual>
      <geometry>
        <mesh filename="package://manip_description/meshes/Link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0.001 0 -0.012" rpy="1.57 0 3.14"/>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <mesh filename="package://manip_description/meshes/Link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0.001 0 -0.012" rpy="1.57 0 3.14"/>
    </collision>

    <inertial>
      <mass value="0.4"/>
      <origin xyz="0.001 0 -0.012" rpy="1.57 0 3.14"/>
      <inertia ixx="0.0004" ixy="0" ixz="0"
               iyy="0.0004" iyz="0"
               izz="0.00008"/>
    </inertial>

  </link>

  <!-- ================= LINK3 ================= -->

  <link name="link3">

    <visual>
      <geometry>
        <mesh filename="package://manip_description/meshes/Link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0.001 0 -0.011" rpy="1.57 0 3.14"/>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <mesh filename="package://manip_description/meshes/Link1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0.001 0 -0.0011" rpy="1.57 0 3.14"/>
    </collision>

    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0004" ixy="0" ixz="0"
               iyy="0.0004" iyz="0"
               izz="0.00008"/>
    </inertial>

  </link>

  <!-- ================= LINK4 ================= -->

  <link name="link4">

    <visual>
      <geometry>
        <mesh filename="package://manip_description/meshes/Link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0.042 0 0.020" rpy="1.57 0 1.57"/>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <mesh filename="package://manip_description/meshes/Link3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0.042 0 0.020" rpy="1.57 0 1.57"/>
    </collision>

    <inertial>
      <mass value="0.3"/>
      <origin xyz="0.042 0 0.020" rpy="1.57 0 1.57"/>
      <inertia ixx="0.0003" ixy="0" ixz="0"
               iyy="0.0003" iyz="0"
               izz="0.00006"/>
    </inertial>

  </link>

  <!-- ================= FLANGE ================= -->

  <link name="link5">

    <visual>
      <geometry>
        <mesh filename="package://manip_description/meshes/Garra430_teste.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0.0005 0 -0.004 " rpy="0.0 0 3.14"/>
      <material name="cyan">
        <color rgba="0 1 1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <mesh filename="package://manip_description/meshes/Garra430_teste.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0.0005 0 -0.004" rpy="0.0 0 3.14"/>
    </collision>

    <inertial>
      <mass value="0.15"/>
      <origin xyz="0.0005 0 -0.004" rpy="0.0 0 3.14"/>
      <inertia ixx="7.9e-05" ixy="0" ixz="0"
               iyy="1.9e-04" iyz="0"
               izz="2.68e-04"/>
    </inertial>

  </link>

  <!-- ================= REALSENSE D455 ================= -->

  <xacro:sensor_d455
      parent="link5"
      name="camera"
      use_nominal_extrinsics="true">

      <!--
      Ajuste da pose da câmera em relação ao flange
      -->

      <origin xyz="0 -0.055 0.009"
              rpy="0 -1.57079632679 -1.57079632679"/>

  </xacro:sensor_d455>

  <!-- ================= ARM JOINTS ================= -->

  <joint name="manip_joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14"
           effort="10" velocity="1"/>
  </joint>

  <joint name="manip_joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.099"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.8"
           effort="10" velocity="3"/>
  </joint>

  <joint name="manip_joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.184"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="2.6"
           effort="10" velocity="1"/>
  </joint>

  <joint name="manip_joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.185"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.2" upper="2.2"
           effort="10" velocity="1"/>
  </joint>

  <joint name="manip_joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0.0013 0 0.08"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14"
           effort="10" velocity="1"/>
  </joint>

  <!-- ================= TCP ================= -->

  <link name="tcp">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-08" ixy="0" ixz="0"
               iyy="1e-08" iyz="0"
               izz="1e-08"/>
    </inertial>
  </link>

  <joint name="tcp_fixed" type="fixed">
    <parent link="link5"/>
    <child link="tcp"/>
    <origin xyz="0 -0.001 0.16" rpy="0 0 0"/>
  </joint>

  <!-- ==================== TCP 2 ==================-->

    <link name="tcp2">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-08" ixy="0" ixz="0"
               iyy="1e-08" iyz="0"
               izz="1e-08"/>
    </inertial>
  </link>

  <joint name="tcp2_fixed" type="fixed">
    <parent link="link5"/>
    <child link="tcp2"/>
    <origin xyz="0 -0.001 0.3" rpy="0 0 0"/>
  </joint>

</robot>